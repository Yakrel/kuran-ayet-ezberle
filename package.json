{
  "name": "kuran-ayet-ezberle",
  "version": "0.0.1",
  "main": "index.ts",
  "scripts": {
    "start": "expo start",
    "start:lan": "expo start --lan --port 19000",
    "start:tunnel": "expo start --tunnel --clear",
    "start:dev-client": "expo start --dev-client --lan --port 19000",
    "postinstall": "patch-package",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "web": "expo start --web",
    "backup:audio": "node scripts/backup-everyayah-audio.mjs",
    "build:dev-client": "eas build -p android --profile development",
    "build:apk": "eas build -p android --profile preview",
    "build:aab": "eas build -p android --profile production"
  },
  "dependencies": {
    "@expo-google-fonts/amiri": "^0.4.1",
    "@expo-google-fonts/noto-naskh-arabic": "^0.4.5",
    "@expo-google-fonts/scheherazade-new": "^0.4.2",
    "@react-native-async-storage/async-storage": "2.2.0",
    "@react-native-picker/picker": "2.11.4",
    "expo": "~55.0.8",
    "expo-build-properties": "~55.0.10",
    "expo-dev-client": "~55.0.18",
    "expo-file-system": "~55.0.11",
    "expo-font": "~55.0.4",
    "expo-localization": "~55.0.9",
    "expo-splash-screen": "~55.0.12",
    "expo-status-bar": "~55.0.4",
    "react": "19.2.0",
    "react-dom": "19.2.0",
    "react-native": "0.83.2",
    "react-native-safe-area-context": "~5.6.2",
    "react-native-track-player": "^4.1.2",
    "react-native-web": "^0.21.0",
    "react-native-zip-archive": "^7.0.2"
  },
  "devDependencies": {
    "@types/react": "~19.2.2",
    "patch-package": "^8.0.1",
    "typescript": "~5.9.2"
  },
  "expo": {
    "doctor": {
      "reactNativeDirectoryCheck": {
        "exclude": [],
        "listUnknownPackages": false
      }
    }
